#!/usr/bin/bash

#SBATCH -J smd
#SBATCH -p xahcnormal
#SBATCH -N 1
#SBATCH --ntasks-per-node=12

current_dir="$HOME/test/committor_ml/test_chignolin/test_3/sampling_cell/pre_sample"
echo "$current_dir"

n_ank=17

for ((i=0; i<$n_ank; i++))
do
    mkdir -p $current_dir/cell_$i
    let "i_1=i-1"

    cp $current_dir/data0/sample_cell.namd $current_dir/cell_$i/
    
    cd $current_dir/data0/
    python3 ./rewrite_colvar.py $i
    cp $current_dir/data0/colvar_sample_cell.conf $current_dir/cell_$i/
    
done



